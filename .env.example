# Reddit Data API (OAuth app-only / client_credentials).
# Obtain these only AFTER your Data API access request is approved and you create
# the app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_app_client_id
REDDIT_CLIENT_SECRET=your_app_client_secret
REDDIT_USERNAME=your_reddit_username   # used in the API User-Agent string

# Email delivery for the private digest (Gmail SMTP).
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
GMAIL_TO_EMAIL=recipient@example.com
